# Environment variables for Nineteen10 Backend

# Server Port
PORT=3000

# Node Environment
NODE_ENV=development

# Backend URL (for CORS and client connections)
BACKEND_URL=http://localhost:3000

# Optional: Database configuration (for future enhancements)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=nineteen10
# DB_USER=username
# DB_PASSWORD=password

# Optional: Redis configuration (for session management)
# REDIS_URL=redis://localhost:6379
